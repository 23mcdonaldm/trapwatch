rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Client SDK only ever touches its own user profile doc directly
    // (frontend/services/firestore.ts). Everything else — odds, events,
    // votes, comments — is written by the backend's Firebase Admin SDK,
    // which bypasses these rules, or read here as public data.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Owners manage their own profile, but the win/loss record is written
      // only by the backend (Admin SDK) — block client tampering.
      allow create: if request.auth != null && request.auth.uid == uid
        && !('record' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['record']);
    }

    // Pick history: owner-only read; written exclusively by the backend.
    match /user_picks/{pickId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // Graded trap outcomes + system records: public read, backend-only write.
    match /trap_results/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /system_records/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Odds/events/traps feed data: public read, admin-only write.
    match /odds/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /events/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Social (votes/comments aggregates): public read, admin-only write.
    match /social/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Collection-group reads (e.g. the live "newest comment across all games"
    // banner) need a rule written against the group wildcard form.
    match /{path=**}/comments/{commentId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
